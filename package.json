{
  "name": "obsidian-tool",
  "version": "0.1.0",
  "description": "CLI-native AI study tool with Socratic tutoring, spaced repetition, and code analysis — writes to Obsidian vault",
  "type": "module",
  "bin": {
    "study": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsx src/build.ts",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "ts-fsrs": "^4.6.0",
    "unicodeit": "^0.7.5",
    "web-tree-sitter": "^0.25.3",
    "voyageai": "^0.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.18",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
